# ─── Ma'lumotlar bazasi (yagona tashqi bog'liqlik) ───
# Lokal PostgreSQL 15+ o'rnatilgan bo'lishi kerak (Docker YO'Q).
DATABASE_URL="postgresql://davlat:davlat@localhost:5432/davlat_mulki?schema=public"

# ─── Auth.js (NextAuth v5) ───
# PowerShell'da yaratish: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Boshlang'ich super-admin (seed uchun) ───
SEED_ADMIN_EMAIL="admin@davlatmulki.uz"
SEED_ADMIN_PASSWORD="change-me-strong-password"

# ─── PDF saqlash (local filesystem) ───
UPLOAD_DIR="./data/uploads"
MAX_UPLOAD_BYTES="20971520" # 20MB

# ─── Worker (pg-boss) — tezlik ───
# O'lchov (193 obyekt): batch=10 + poll=2s => ~100s, shundan ~80s BO'SH KUTISH edi.
# batch=25 + poll=1s => 22s. Endi cheklovchi omil rate limit (API_RATE_MAX), kutish emas.
# batch'ni oshirsangiz Prisma pool'ini ham oshiring: DATABASE_URL'ga ?connection_limit=30
WORKER_CONCURRENCY="25"      # bir batch'dagi parallel joblar
WORKER_POLL_SECONDS="1"      # navbatni tekshirish oralig'i

# ─── Tashqi API'lar (integratsiya) ───
# API 1: STIR -> kadastrlar ro'yxati. TOKEN TALAB QILINMAYDI.
# So'rov (jonli API'da tasdiqlangan): GET {API1_BASE_URL}/{API1_PATH}?num={STIR}
#   - parametr nomi `num` (javobda `inn` bo'lib qaytadi)
#   - code=1 muvaffaqiyat; code=2 => STIR noto'g'ri formatda
# To'liq yo'l base URL ichida bo'lsa, API1_PATH ni bo'sh qoldiring.
API1_BASE_URL="http://"
API1_PATH=""
# API 2: kadastr -> asosiy ma'lumot (UZKAD). cad_number_old shu yerdan keladi.
# So'rov (jonli API'da tasdiqlangan): GET {API2_BASE_URL}/{API2_PATH}?num={KADASTR}&token={API2_TOKEN}
#   - token QUERY parametr sifatida ketadi, headerda EMAS (tokensiz endpoint 404 beradi)
#   - code=1 muvaffaqiyat; code=2 => kadastr raqami noto'g'ri formatda
#   - DIQQAT: cad_number_old topilmasa "" (bo'sh satr) keladi — kod uni null'ga aylantiradi
API2_BASE_URL="http://"
API2_PATH=""
API2_TOKEN=""
# API 3-8: kadastr -> holat tekshiruvlari
API3_BASE_URL="https://example.gov.uz/api3"
API4_BASE_URL="https://example.gov.uz/api4"
API5_BASE_URL="https://example.gov.uz/api5"
API6_BASE_URL="https://example.gov.uz/api6"
API7_BASE_URL="https://example.gov.uz/api7"
API8_BASE_URL="https://example.gov.uz/api8"
API_STATUS_TOKEN=""

# ─── Rate limit (tashqi API'ga so'rovlar) ───
API_RATE_MAX="10"        # duration ichida maksimal so'rov
API_RATE_DURATION_MS="1000"
API_MAX_ATTEMPTS="5"
API_TIMEOUT_MS="15000"
